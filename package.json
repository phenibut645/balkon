{
  "name": "balkon-bot",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=dev tsx watch src/bot.ts",
    "dev:api": "cross-env NODE_ENV=dev tsx src/api/server.ts",
    "start": "cross-env NODE_ENV=prod node dist/bot.js",
    "start:api": "cross-env NODE_ENV=prod node dist/api/server.js",
    "start:prod": "npm run build && npm run start",
    "start:prod:tsx": "cross-env NODE_ENV=prod tsx src/bot.ts",
    "pm2:start": "pm2 start ecosystem.config.cjs --only balkon-bot",
    "pm2:restart": "pm2 restart balkon-bot",
    "pm2:stop": "pm2 stop balkon-bot",
    "pm2:logs": "pm2 logs balkon-bot",
    "agent": "tsx src/agent/obsAgent.ts",
    "dev-deploy": "cross-env NODE_ENV=dev tsx src/deploy_commands.ts",
    "prod-deploy": "cross-env NODE_ENV=prod tsx src/deploy_commands.ts",
    "db:init": "node scripts/init_schema.mjs",
    "db:init:dev": "cross-env NODE_ENV=dev node scripts/init_schema.mjs",
    "db:init:prod": "cross-env NODE_ENV=prod node scripts/init_schema.mjs",
    "db:migrate:dev": "cross-env NODE_ENV=dev node scripts/run_migrations.mjs",
    "db:migrate:prod": "cross-env NODE_ENV=prod node scripts/run_migrations.mjs",
    "seed-demo": "cross-env NODE_ENV=dev node scripts/seed_demo_content.mjs",
    "build": "tsc && node scripts/copy_runtime_assets.mjs"
  },
  "dependencies": {
    "@discordjs/rest": "^2.6.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "discord.js": "^14.22.1",
    "dotenv": "^17.2.2",
    "fastify": "^5.8.5",
    "mysql2": "^3.14.5",
    "obs-websocket-js": "^5.0.8",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "cross-env": "^10.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
