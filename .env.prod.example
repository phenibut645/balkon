DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=balkon

TWITCH_CLIENT_ID=
TWITCH_SECRET_ID=

DEVELOPER_DISCORD_ID=
BOT_ADMIN_IDS=

# OBS relay server used by the standalone Balkon OBS Agent desktop app.
OBS_AGENT_RELAY_PORT=8787
OBS_AGENT_REQUEST_TIMEOUT_MS=10000

# Legacy/development-only direct OBS config.
# Normal production OBS control should use OBS Agent relay mode.
OBS_WEBSOCKET_URL=ws://127.0.0.1:4455
OBS_WEBSOCKET_PASSWORD=

# Discord OAuth2 for the future website/API login.
# DISCORD_OAUTH_CLIENT_ID can usually match CLIENT_ID.
# DISCORD_OAUTH_CLIENT_SECRET must never be committed with a real value.
# Redirect URI must exactly match Discord Developer Portal.
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=https://your-api-domain.example/api/auth/discord/callback
DISCORD_OAUTH_SCOPES=identify guilds

# Future website/API runtime.
# Do not expose the API publicly until Discord OAuth/session auth is implemented and configured.
WEB_HOST=0.0.0.0
WEB_PORT=3001
WEB_CORS_ORIGIN=https://your-website-domain.example
WEB_SESSION_SECRET=replace-with-long-random-secret
WEB_APP_URL=https://your-website-domain.example
WEB_APP_AUTH_SUCCESS_URL=https://your-website-domain.example
WEB_APP_AUTH_ERROR_URL=https://your-website-domain.example/login?error=oauth

# API session cookie.
API_SESSION_COOKIE_NAME=balkon_session
API_SESSION_TTL_DAYS=14

# Must stay false or empty in production.
# Dev headers are ignored in NODE_ENV=prod anyway.
API_DEV_AUTH_ENABLED=false

# Interactive command session tuning.
COMMAND_SESSION_TTL_MS=120000
COMMAND_SESSION_MAX_ACTIVE=2000
COMMAND_SESSION_INTERACTION_COOLDOWN_MS=750

# Optional Discord monetization / Balkon Plus.
SUBSCRIPTION_GUILD_ID=
BALKON_PLUS_SKU_ID=
BALKON_PLUS_ROLE_ID=
SUBSCRIPTION_SYNC_INTERVAL_MS=900000